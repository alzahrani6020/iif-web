{
  "name": "government-search-system",
  "version": "1.0.0",
  "description": "Comprehensive Government Search System with Backend Database",
  "main": "backend-server.js",
  "scripts": {
    "start": "node backend-server.js",
    "dev": "nodemon backend-server.js",
    "test": "node scripts/test-budget-parse.js",
    "test:anchors": "node scripts/check-anchor-targets.cjs",
    "test:site": "npm run test:anchors && npm run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "playwright:install": "playwright install chromium",
    "i18n:keys": "node scripts/check-i18n-keys.js",
    "i18n:keys:strict": "node scripts/check-i18n-keys.js --strict",
    "i18n:locales": "node scripts/verify-i18n-locales.cjs",
    "i18n:packs": "node emit-service-packs.cjs",
    "lh": "node scripts/lighthouse-iif.js",
    "fonts:vendor": "node scripts/vendor-fontsource-woff2.js",
    "postinstall": "node scripts/postinstall.cjs",
    "csp:sync": "node scripts/sync-csp.js",
    "assets:optimize": "node scripts/optimize-assets.js"
  },
  "keywords": [
    "government",
    "search",
    "database",
    "arabic",
    "english",
    "bilingual"
  ],
  "author": "Government Search Team",
  "license": "MIT",
  "dependencies": {
    "@fontsource/noto-sans-arabic": "^5.2.10",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "sqlite3": "^5.1.6",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.49.1",
    "nodemon": "^3.1.14",
    "sharp": "^0.34.5"
  },
  "engines": {
    "node": ">=22"
  }
}

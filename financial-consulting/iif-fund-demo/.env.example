# نسخ إلى .env محلي (لا ترفع الأسرار إلى Git)
# اختبار بروكسي SearX محلياً عبر Vercel CLI فقط — على الإنتاج ضبط المتغيرات من لوحة Vercel
#
# خادم Node (backend-server.js): منفذ API + ملفات الميزانية POST /api/budget/parse
# PORT=3000
# الواجهة على dev مثلاً 3333: في index.html استخدم meta iif-budget-api-base أو اتركه فارغاً للافتراضي 127.0.0.1:3000
#
# نموذج «اتصل بنا»: ليس متغير .env — عيّن في index.html meta iif-contact-form-endpoint أو IIF_CONFIG.contactFormEndpoint (Formspree/Getform)

# مثيل SearXNG الذي يستدعيه api/searx/search.js (افتراضي: searx.tiekoetter.com)
# SEARX_UPSTREAM=https://searx.tiekoetter.com

# حد معدل الطلبات لكل IP (اختياري)
# IIF_PROXY_RL_MAX=45
# IIF_PROXY_RL_WINDOW_MS=60000
# IIF_PROXY_RL_OFF=1

# موجز الأخبار (api/news.js + dev-server /api/news)
# IIF_NEWS_CACHE_MS=120000
# حد طلبات /api/news لكل IP (محلي فقط عبر dev-server)
# IIF_RL_NEWS_MAX=90
# ترجمة عناوين إنجليزية → عربية عبر خدمة NLLB (عقد POST /translate مثل search.html)
# IIF_TICKER_TRANSLATE_URL=http://127.0.0.1:7071
# IIF_TICKER_TRANSLATE_MAX=8
# IIF_TICKER_TRANSLATE_TIMEOUT_MS=45000

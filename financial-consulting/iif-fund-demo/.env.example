# نسخ إلى .env محلي (لا ترفع الأسرار إلى Git)
# اختبار بروكسي SearX محلياً عبر Vercel CLI فقط — على الإنتاج ضبط المتغيرات من لوحة Vercel

# مثيل SearXNG الذي يستدعيه api/searx/search.js (افتراضي: searx.tiekoetter.com)
# SEARX_UPSTREAM=https://searx.tiekoetter.com

# حد معدل الطلبات لكل IP (اختياري)
# IIF_PROXY_RL_MAX=45
# IIF_PROXY_RL_WINDOW_MS=60000
# IIF_PROXY_RL_OFF=1

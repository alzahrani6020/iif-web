# انسخ الأسماء إلى Netlify: Site settings → Environment variables
# احتفظ بنسخة آمنة من القيم خارج المستودع (مدير كلمات مرور / لوحة فريق).
# لا ترفع هذا الملف بأسرار حقيقية إلى مستودع عام.

# --- تشغيل نشر يدوي من الطرفية (محلي فقط، لا تضفها لموقع Netlify) ---
# أنشئ Build hook: Site → Build & deploy → Build hooks
# ثم على جهازك: $env:NETLIFY_BUILD_HOOK_URL="https://api.netlify.com/build_hooks/..." ; npm run netlify:build:trigger
# NETLIFY_BUILD_CLEAR_CACHE=1  (اختياري) يضيف ?clear_cache=true
#
# بديل إذا كان الموقع غير مربوط بـ Git (build hook قد يرجع 200 بدون بناء):
# NETLIFY_SITE_ID=4d4c58f4-8834-4567-afa9-849abc535ea4
# NETLIFY_AUTH_TOKEN=...   (محلياً فقط؛ أو نفّذ netlify login)
# NETLIFY_BUILD_BRANCH=main
# NETLIFY_BUILD_TITLE=manual-build
# NETLIFY_BUILD_ZIP=C:\path\to\site.zip   (اختياري؛ وإلا يستخدم git archive)

# مسار الإنتاج الكامل (نطاق VPS + Netlify): npm run searxng:path
#
# --- بحث (SearXNG عبر دالة Netlify) ---
# إن لم تُضبط، يُقرأ الافتراضي من netlify.toml (tiekoetter) في كثير من النشرات.
# عدة مثيلات (فاصلة إنجليزية): إعادة محاولة تلقائية عند 429 أو 502/503/504 أو انقطاع.
# SEARXNG_URL=https://searx.tiekoetter.com,https://search.example.com
SEARXNG_URL=https://search.example.com
IIF_SEARX_TIMEOUT_MS=15000
# اختياري: إن كان format=json و results فارغة، جرّب المثيل التالي في القائمة (يزيد زمن الاستجابة).
# IIF_SEARX_RETRY_EMPTY=1
# الدالة تمرّر Accept-Language من المتصفح إلى SearXNG لتحسين الملاءمة (لا يحتاج متغيراً إضافياً).
# تخزين مؤقت لاستجابات JSON الناجحة (يقلّل 429 عند تكرار نفس الاستعلام): افتراضي 120 ثانية داخل الدالة.
# IIF_SEARX_CACHE_MS=120000
# IIF_SEARX_CACHE_MAX=100
# IIF_SEARX_CACHE_MS=0   (لتعطيل الكاش بالكامل)

# --- ترجمة (مترجمكم NLLB على /translate) ---
# إن لم تُضبط، تستخدم الدالة LibreTranslate الاحتياطي (مثيلات عامة — للاختبار فقط).
IIF_TRANSLATE_URL=https://translator.example.com
IIF_TRANSLATE_TIMEOUT_MS=180000

# اختياري — مثيل LibreTranslate عند الاعتماد على الاحتياطي فقط
# IIF_TRANSLATE_LIBRE_URL=https://libretranslate.de
# IIF_TRANSLATE_LIBRE_API_KEY=

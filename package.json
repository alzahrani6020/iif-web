{
  "name": "iif-fund-demo",
  "private": true,
  "description": "منصة حكومية + واجهة صندوق — محرك بحث منفصل (engines/searxng)",
  "scripts": {
    "start": "node scripts/dev-server.js",
    "dev": "node scripts/dev-server.js",
    "check-urls": "node scripts/check-urls.js",
    "check:dev": "node scripts/check-urls.js",
    "check:news-feeds": "node scripts/check-news-feeds.mjs",
    "smoke:html": "node scripts/smoke-html-check.mjs",
    "smoke:news": "node scripts/smoke-news-api.mjs",
    "smoke:with-server": "node scripts/smoke-with-server.mjs",
    "verify:full": "npm run verify && node scripts/smoke-with-server.mjs",
    "build:gov-data": "node financial-consulting/government-search/build-government-data.mjs",
    "expand:gov-un195": "node financial-consulting/government-search/expand-government-data-to-un195.mjs",
    "fix:worldbank-urls": "node financial-consulting/government-search/fix-worldbank-country-urls.mjs",
    "i18n:packs": "node financial-consulting/iif-fund-demo/emit-service-packs.cjs",
    "install:git-hooks": "node scripts/install-git-hooks.js",
    "prepare": "node scripts/prepare-git-hooks.js",
    "verify:i18n-packs-sync": "git diff --exit-code HEAD -- financial-consulting/iif-fund-demo/i18n-service-packs-a.js financial-consulting/iif-fund-demo/i18n-service-packs-b.js financial-consulting/iif-fund-demo/i18n-service-packs-c.js financial-consulting/iif-fund-demo/i18n-service-packs-d.js financial-consulting/iif-fund-demo/i18n-service-packs-all.js",
    "verify:thiqqah-i18n": "python scripts/verify-thiqqah-i18n.py && python scripts/find-missing-page-ar.py",
    "verify:thiqqah:live-domain": "node scripts/verify-thiqqah-live-domain.mjs",
    "verify:iiffund:https": "node scripts/verify-iiffund-https.mjs",
    "lint": "eslint scripts netlify financial-consulting/iif-fund-demo/api",
    "check:deploy": "node scripts/deploy-readiness.mjs",
    "build": "npm run build:gov-data && npm run i18n:packs",
    "build:github-pages": "npm run build && node scripts/prepare-github-pages-site.mjs",
    "validate": "npm run build",
    "verify": "npm run build && node --check scripts/dev-server.js && node --check scripts/check-urls.js && node --check scripts/smoke-with-server.mjs && node --check scripts/smoke-news-api.mjs && node --check scripts/check-news-feeds.mjs && node --check scripts/e2e-public-viewports.mjs && node --check scripts/maintenance-full-audit.mjs && node --check scripts/lib/dotenv-load.mjs && node --check scripts/minimax-ask.mjs && node --check scripts/minimax-env-status.mjs && node --check scripts/verify-netlify-proxy.mjs && node --check scripts/smoke-live-site.mjs && node --check scripts/netlify-upsert-site-env.mjs && node --check scripts/searxng-production-path.mjs && node --check scripts/trigger-netlify-build.cjs && node --check netlify/functions/searx.js && node --check netlify/functions/healthz.js && node --check financial-consulting/iif-fund-demo/api/user-registration-forward.js && node --check netlify/functions/news.js && node --check netlify/functions/check-content.js",
    "verify:local": "npm run verify && node scripts/maintenance-full-audit.mjs",
    "health": "npm run maintenance:audit && npm run check-urls && npm run smoke:html && npm run smoke:news",
    "verify:searx": "node scripts/verify-searx.js",
    "verify:proxy": "node scripts/verify-netlify-proxy.mjs",
    "smoke:live": "node scripts/smoke-live-site.mjs",
    "netlify:env:sync": "node scripts/netlify-upsert-site-env.mjs",
    "netlify:build:trigger": "node scripts/trigger-netlify-build.cjs",
    "netlify:thiqqah:setup": "node scripts/open-netlify-thiqqah-setup.cjs",
    "searxng:path": "node scripts/searxng-production-path.mjs",
    "verify:stack": "npm run verify && npm run verify:searx",
    "qa:iif-fund": "node scripts/smoke-html-check.mjs",
    "test:iif-site": "npm run test:site --prefix financial-consulting/iif-fund-demo",
    "e2e:dashboard": "node scripts/e2e-dashboard-playwright.mjs",
    "e2e:public": "node scripts/e2e-public-viewports.mjs",
    "report:index-size": "node scripts/report-index-size.mjs",
    "maintenance:audit": "node scripts/maintenance-full-audit.mjs",
    "maintenance:audit:server": "node scripts/maintenance-full-audit.mjs --with-server",
    "maintenance:audit:external": "node scripts/maintenance-full-audit.mjs --external",
    "maintenance:full": "npm run verify && node scripts/maintenance-full-audit.mjs && node scripts/smoke-with-server.mjs",
    "maintenance:full:live": "npm run verify && node scripts/maintenance-full-audit.mjs --with-server",
    "minimax:ask": "node scripts/minimax-ask.mjs",
    "minimax:status": "node scripts/minimax-env-status.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "i18n-iso-countries": "^7.14.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.2",
    "world-countries": "^5.1.0"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0"
  }
}
